  "query": "SELECT cp.phoneNumber, c.propertyId, COUNT(*) as cnt, GROUP_CONCAT(cp.id) as phone_ids, GROUP_CONCAT(c.id) as contact_ids\nFROM contactPhones cp\nJOIN contacts c ON cp.contactId = c.id\nWHERE c.propertyId IS NOT NULL\nGROUP BY cp.phoneNumber, c.propertyId\nHAVING COUNT(*) > 1\nORDER BY cnt DESC\nLIMIT 50;",
